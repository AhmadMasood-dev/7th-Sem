<div class="mb-3">
  <label class="form-label">Name</label>
  <input
    name="productName"
    class="form-control"
    value="<%= product.productName || '' %>"
    required
  />
</div>
<div class="mb-3">
  <label class="form-label">Firm</label>
  <input
    name="firmName"
    class="form-control"
    value="<%= product.firmName || '' %>"
  />
</div>
<div class="mb-3">
  <label class="form-label">Price</label>
  <input
    name="price"
    type="number"
    step="0.01"
    class="form-control"
    value="<%= product.price || '' %>"
  />
</div>
<div class="mb-3">
  <label class="form-label">Quantity</label>
  <input
    name="quantity"
    type="number"
    class="form-control"
    value="<%= product.quantity || '' %>"
  />
</div>
<div class="mb-3">
  <label class="form-label">Expiry Date</label>
  <input
    name="expiryDate"
    type="date"
    class="form-control"
    value="<%= product.expiryDate ? product.expiryDate.toISOString().slice(0,10) : '' %>"
  />
</div>
