<% title = 'Products' %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="m-0">Products</h1>
  <a class="btn btn-primary" href="/products/new">Create New Product</a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
  <% products.forEach(p => { %>
  <div class="col">
    <div class="card h-100">
      <div class="card-body d-flex flex-column">
        <h5 class="card-title">
          <a
            href="/products/<%= p._id %>"
            class="stretched-link text-decoration-none"
            ><%= p.productName %></a
          >
        </h5>
        <p class="card-text mb-1"><strong>Firm:</strong> <%= p.firmName %></p>
        <p class="card-text mb-1"><strong>Price:</strong> $<%= p.price %></p>
        <p class="card-text mb-3">
          <strong>Quantity:</strong> <%= p.quantity %>
        </p>
        <div class="mt-auto d-flex gap-2">
          <a
            class="btn btn-sm btn-outline-secondary"
            href="/products/<%= p._id %>/edit"
            >Edit</a
          >
          <button
            class="btn btn-sm btn-danger btn-delete"
            data-action="/products/<%= p._id %>?_method=DELETE"
          >
            Delete
          </button>
        </div>
      </div>
      <div class="card-footer text-muted small">
        Expiry: <%= p.expiryDate ? p.expiryDate.toISOString().slice(0,10) : '—'
        %>
      </div>
    </div>
  </div>
  <% }) %>
</div>

<%- include('../partials/_confirmDelete') %>
