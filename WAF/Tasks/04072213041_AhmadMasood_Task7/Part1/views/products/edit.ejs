<% title = 'Edit Product' %>
<h1>Edit Product</h1>
<form action="/products/<%= product._id %>?_method=PUT" method="POST">
  <%- include('../partials/_form', { product: product }) %>
  <button class="btn btn-primary">Save</button>
  <a class="btn btn-secondary" href="/products/<%= product._id %>">Cancel</a>
</form>
