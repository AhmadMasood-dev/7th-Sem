<% title = 'Edit CV' %>
<h1>Edit CV</h1>
<form
  action="/resumes/<%= resume._id %>?_method=PATCH"
  method="POST"
  enctype="multipart/form-data"
>
  <%- include('partials/_form', { resume: resume }) %>
  <div class="mt-3">
    <button class="btn btn-primary">Save Changes</button>
    <a class="btn btn-secondary" href="/resumes/<%= resume._id %>">Cancel</a>
  </div>
</form>
